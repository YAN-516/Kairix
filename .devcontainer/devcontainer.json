{
  "name": "Kairix-OS-Contest-Env",
  "image": "docker.educg.net/cg/os-contest:20250614",

   "postCreateCommand": "apt-get update && apt-get install -y e2fsprogs e2tools",//用于打包ext4

  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",        
        "tamasfe.even-better-toml",       
        "vadimcn.vscode-lldb",             
        "dan-c-underwood.software-visual-studio-code-riscv-asm" 
      ]
    }
  },
  "containerEnv": {
    "LANG": "C.UTF-8",
    "LC_ALL": "C.UTF-8",
    "LC_CTYPE": "C.UTF-8",
    "TERM": "xterm-256color"
  },
  
  "remoteEnv": {
    "LANG": "C.UTF-8",
    "LC_ALL": "C.UTF-8",
    "LC_CTYPE": "C.UTF-8",
    "TERM": "xterm-256color"
  },
  "remoteUser": "root",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "source=kairix-rustup,target=/root/.rustup,type=volume",
    "source=kairix-cargo,target=/root/.cargo,type=volume",
    "source=kairix-vscode-server,target=/root/.vscode-server,type=volume"
  ],

  "runArgs": [
    "--privileged",
    "--network=host"
  ]


}